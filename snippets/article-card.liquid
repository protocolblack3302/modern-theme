<article class="article-card" data-animate="fade-up">
  {%- if article.image -%}
    <a href="{{ article.url }}" class="article-card__media" tabindex="-1" aria-hidden="true">
      <img
        src="{{ article.image | image_url: width: 700 }}"
        alt="{{ article.image.alt | escape | default: article.title }}"
        width="700"
        height="467"
        loading="lazy"
      >
    </a>
  {%- endif -%}

  <div class="article-card__body">
    <div class="article-card__meta">
      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
        {{ article.published_at | date: '%b %d, %Y' }}
      </time>
      {%- if article.tags.size > 0 -%}
        <span class="article-card__tag">{{ article.tags.first }}</span>
      {%- endif -%}
    </div>

    <h3 class="article-card__title">
      <a href="{{ article.url }}">{{ article.title }}</a>
    </h3>

    {%- if article.excerpt_or_content != blank -%}
      <p class="article-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 130 }}</p>
    {%- endif -%}

    <a href="{{ article.url }}" class="article-card__read-more">
      Read more
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</article>
