<div
  class="cart-drawer"
  :class="{ 'cart-drawer--open': $store.cart.open }"
  @keydown.escape.window="$store.cart.closeDrawer()"
  @keydown.tab="$store.cart.trapFocus($event)"
  tabindex="-1"
  role="dialog"
  aria-label="{{ 'cart.title' | t }}"
  aria-modal="true"
>

  <!-- Header -->
  <div class="cart-drawer-header">
    <h2 class="cart-drawer-title">{{ 'cart.title' | t }}</h2>
    <div class="cart-drawer-header__actions">
      <button
        type="button"
        class="cart-drawer-clear"
        :class="{ 'cart-drawer-clear--confirming': $store.cart.confirmingClear }"
        x-show="$store.cart.items.length > 0"
        @click="$store.cart.requestClear()"
        :disabled="$store.cart.clearing"
        x-text="$store.cart.confirmingClear ? 'Tap again to confirm' : 'Clear cart'"
      ></button>
      <button
        type="button"
        class="cart-drawer-close header-icon-btn"
        @click="$store.cart.closeDrawer()"
        aria-label="{{ 'general.close' | t }}"
      >
        {%- render 'icon-close' -%}
      </button>
    </div>
  </div>

  <!-- Error banner -->
  <div
    class="cart-error-banner"
    x-show="$store.cart.errorMessage"
    x-text="$store.cart.errorMessage"
    @click="$store.cart.clearError()"
    role="alert"
  ></div>

  <!-- Body -->
  <div class="cart-drawer-body">

    <!-- Empty state -->
    <div class="cart-empty" x-show="$store.cart.items.length === 0">
      <div class="cart-empty-icon">
        {%- render 'icon-cart' -%}
      </div>
      <p>{{ 'cart.empty' | t }}</p>
      <button type="button" class="btn btn--ghost" @click="$store.cart.closeDrawer()">
        {{ 'cart.continue_shopping' | t }}
      </button>
    </div>

    <!-- Items list -->
    <div x-show="$store.cart.items.length > 0">
      <template x-for="item in $store.cart.items" :key="item.key">
        <div class="cart-item" :class="{ 'cart-item--updating': $store.cart.linePending(item.key) }">

          <!-- Product image -->
          <a :href="item.url">
            <img
              class="cart-item__img"
              :src="item.image"
              :alt="item.title"
              width="80"
              height="107"
              loading="lazy"
            >
          </a>

          <!-- Details -->
          <div class="cart-item__details">
            <a :href="item.url" class="cart-item__title" x-text="item.product_title"></a>

            <p class="cart-item__variant" x-show="item.variant_title && item.variant_title !== 'Default Title'" x-text="item.variant_title"></p>

            <p class="cart-item__price" x-text="$store.cart.formattedPrice(item.final_price ?? item.price)"></p>

            <div class="cart-item__footer">
              <!-- Qty control -->
              <div class="qty-control">
                <button
                  type="button"
                  class="qty-btn"
                  @click="$store.cart.changeItem(item.key, -1)"
                  :disabled="$store.cart.clearing || $store.cart.linePending(item.key)"
                  aria-label="Decrease quantity"
                >−</button>
                <span class="qty-value" x-text="item.quantity"></span>
                <button
                  type="button"
                  class="qty-btn"
                  @click="$store.cart.changeItem(item.key, 1)"
                  :disabled="$store.cart.clearing || $store.cart.linePending(item.key) || $store.cart.atStockLimit(item)"
                  aria-label="Increase quantity"
                >+</button>
              </div>

              <button
                type="button"
                class="cart-item__remove"
                @click="$store.cart.removeItem(item.key)"
                :disabled="$store.cart.clearing"
              >
                {{ 'cart.remove' | t }}
              </button>
            </div>
          </div>

        </div>
      </template>
    </div>

  </div>

  <!-- Footer -->
  <div class="cart-drawer-footer" x-show="$store.cart.items.length > 0">
    <div class="cart-subtotal">
      <span class="cart-subtotal__label">{{ 'cart.subtotal' | t }}</span>
      <span class="cart-subtotal__amount" x-text="$store.cart.formattedTotal"></span>
    </div>

    <form action="{{ routes.cart_url }}" method="post">
      <button type="submit" name="checkout" class="btn btn--primary btn--full">
        {{ 'cart.checkout' | t }}
      </button>
    </form>

    <p class="cart-note">Taxes and shipping calculated at checkout</p>
  </div>

</div>
