<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#080808">

  <title>
    {{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- else -%}
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23080808'/><text x='50' y='72' font-size='68' font-family='Arial Black' font-weight='900' fill='%23c8102e' text-anchor='middle'>A</text></svg>">
  {%- endif -%}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <!-- GSAP + ScrollTrigger (load before theme.js so animations are available) -->
  <script defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

  <!-- Lenis smooth scroll -->
  <script defer src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/bundled/lenis.min.js"></script>

  <!-- theme.js MUST load before Alpine so its alpine:init listeners
       (Alpine.store('cart') + Alpine.data('productPage')) are registered
       before Alpine starts. -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  <!-- Alpine.js — loaded LAST so all alpine:init listeners exist first -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

  <!-- CSS custom properties from settings -->
  <style>
    :root {
      --color-bg: {{ settings.color_bg }};
      --color-surface: {{ settings.color_surface }};
      --color-accent: {{ settings.color_accent }};
      --color-text: {{ settings.color_text }};
      --color-text-muted: {{ settings.color_text_muted }};
      --color-border: {{ settings.color_border }};
      --page-max: {{ settings.page_width }}px;
    }
  </style>

  {{ content_for_header }}
</head>

<body
  x-data
  x-init="$store.cart.init()"
  class="template-{{ template.name }}{% if template.suffix %}-{{ template.suffix }}{% endif %}"
>

  {%- section 'announcement-bar' -%}
  {%- section 'header' -%}

  <!-- Cart Drawer -->
  {%- render 'cart-drawer' -%}

  <!-- Cart / drawer overlay -->
  <div
    class="overlay"
    :class="{ 'overlay--visible': $store.cart.open }"
    @click="$store.cart.closeDrawer()"
  ></div>

  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

</body>
</html>
