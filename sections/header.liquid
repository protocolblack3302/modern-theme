<header class="site-header" role="banner" {% unless template.name == 'index' %}data-solid{% endunless %}>
  <div class="header-inner">

    <!-- Desktop nav (left) -->
    <nav class="header-nav" aria-label="Main navigation">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" {% if link.active %}aria-current="page"{% endif %}>
          {{ link.title }}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}">Home</a>
        <a href="{{ routes.all_products_collection_url }}">Shop</a>
        <a href="/pages/about">About</a>
        <a href="/pages/contact">Contact</a>
      {%- endfor -%}
    </nav>

    <!-- Logo (center) -->
    <div class="header-logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round -%}
          <img
            src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width }}"
            height="{{ logo_height }}"
            loading="eager"
          >
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>
    </div>

    <!-- Actions (right) -->
    <div class="header-actions">

      <!-- Light / Dark mode toggle -->
      <button type="button" id="theme-toggle" class="header-icon-btn theme-toggle-btn" aria-label="Toggle light/dark mode">
        <!-- Sun: shown in dark mode — click to switch to light -->
        <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon: shown in light mode — click to switch to dark -->
        <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Search -->
      <a href="{{ routes.search_url }}" class="header-icon-btn" aria-label="Search">
        {%- render 'icon-search' -%}
      </a>

      <!-- Account — hidden on mobile (accessible via hamburger menu) -->
      <a
        href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
        class="header-icon-btn header-account-btn"
        aria-label="{{ 'account.my_account' | t }}"
      >
        {%- render 'icon-account' -%}
      </a>

      <!-- Cart -->
      <button
        type="button"
        class="header-icon-btn"
        @click="$store.cart.openDrawer()"
        aria-label="{{ 'cart.title' | t }}"
      >
        {%- render 'icon-cart' -%}
        <span
          class="cart-count"
          x-show="$store.cart.totalQuantity > 0"
          :data-count="$store.cart.totalQuantity"
          x-text="$store.cart.totalQuantity"
        ></span>
      </button>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="header-icon-btn header-hamburger"
        @click="$store.menu.toggle()"
        aria-label="Open menu"
        :aria-expanded="$store.menu.open"
      >
        {%- render 'icon-hamburger' -%}
      </button>

    </div>
  </div>
</header>

<!-- Mobile fullscreen menu -->
<div
  class="mobile-menu"
  x-show="$store.menu.open"
  @keydown.escape.window="$store.menu.close()"
  role="dialog"
  aria-label="Mobile navigation"
  style="display:none"
>
  <div class="mobile-menu-header">
    <div class="header-logo">
      <a href="{{ routes.root_url }}" @click="$store.menu.close()">
        {%- if section.settings.logo != blank -%}
          {%- assign mobile_logo_width = section.settings.logo_width | divided_by: 2 -%}
          {%- assign mobile_logo_height = mobile_logo_width | divided_by: section.settings.logo.aspect_ratio | round -%}
          <img src="{{ section.settings.logo | image_url: width: mobile_logo_width }}" alt="{{ shop.name }}" width="{{ mobile_logo_width }}" height="{{ mobile_logo_height }}" loading="lazy">
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>
    </div>
    <button type="button" class="header-icon-btn" @click="$store.menu.close()" aria-label="Close menu">
      {%- render 'icon-close' -%}
    </button>
  </div>

  <nav class="mobile-nav" aria-label="Mobile navigation">
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}" @click="$store.menu.close()">{{ link.title }}</a>
    {%- else -%}
      <a href="{{ routes.root_url }}" @click="$store.menu.close()">Home</a>
      <a href="{{ routes.all_products_collection_url }}" @click="$store.menu.close()">Shop</a>
      <a href="/pages/about" @click="$store.menu.close()">About</a>
      <a href="/pages/contact" @click="$store.menu.close()">Contact</a>
    {%- endfor -%}
  </nav>

  <div class="mobile-menu-footer">
    <!-- Account link in mobile menu — always visible -->
    {%- if customer -%}
      <a href="{{ routes.account_url }}" @click="$store.menu.close()" class="mobile-menu-account">
        My Account
      </a>
      <a href="{{ routes.account_logout_url }}" class="mobile-menu-account">
        Log Out
      </a>
    {%- else -%}
      <a href="{{ routes.account_login_url }}" @click="$store.menu.close()" class="mobile-menu-account">
        Sign In
      </a>
      <a href="{{ routes.account_register_url }}" @click="$store.menu.close()" class="mobile-menu-account">
        Register
      </a>
    {%- endif -%}

    {%- if settings.social_instagram != blank -%}
      <a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener noreferrer">Instagram</a>
    {%- endif -%}

    <!-- Theme toggle — only shown in mobile menu (header toggle hidden at ≤960px) -->
    <button type="button" id="theme-toggle-mobile" class="mobile-menu-account mobile-theme-toggle" aria-label="Toggle light/dark mode">
      <span class="mobile-theme-day">☀ Day</span>
      <span class="mobile-theme-night">☽ Night</span>
    </button>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
