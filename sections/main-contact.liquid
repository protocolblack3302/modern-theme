<div style="padding-top: calc(72px + 4rem); padding-bottom: var(--section-gap);">
  <div class="container">
    <div class="page-content" style="max-width: 560px;" data-animate="fade-up">
      <h1>{{ page.title }}</h1>

      {%- if page.content != blank -%}
        <div style="margin-bottom: 2rem; color: var(--color-text-muted);">{{ page.content }}</div>
      {%- endif -%}

      {%- form 'contact', id: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <p style="color: var(--color-accent); margin-bottom: 1.5rem; font-weight: 500;">Thanks! We'll get back to you soon.</p>
        {%- endif -%}

        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div>
            <label for="contact-name" style="display: block; font-size: var(--size-xs); font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 0.5rem;">Name</label>
            <input
              type="text"
              id="contact-name"
              name="contact[name]"
              autocomplete="name"
              style="width: 100%; padding: 0.75rem 1rem; background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); border-radius: var(--radius-sm); transition: border-color var(--dur-fast);"
            >
          </div>

          <div>
            <label for="contact-email" style="display: block; font-size: var(--size-xs); font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 0.5rem;">Email *</label>
            <input
              type="email"
              id="contact-email"
              name="contact[email]"
              required
              autocomplete="email"
              style="width: 100%; padding: 0.75rem 1rem; background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); border-radius: var(--radius-sm); transition: border-color var(--dur-fast);"
            >
          </div>

          <div>
            <label for="contact-message" style="display: block; font-size: var(--size-xs); font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 0.5rem;">Message</label>
            <textarea
              id="contact-message"
              name="contact[body]"
              rows="5"
              style="width: 100%; padding: 0.75rem 1rem; background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); border-radius: var(--radius-sm); resize: vertical; transition: border-color var(--dur-fast);"
            ></textarea>
          </div>

          <button type="submit" class="btn btn--primary">Send Message</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "Contact" }]
}
{% endschema %}
