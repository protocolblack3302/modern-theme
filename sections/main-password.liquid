<div style="min-height: 100svh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: var(--gutter); text-align: center; background: var(--color-bg);">
  <div style="max-width: 440px; width: 100%;">

    <p style="font-family: var(--font-heading); font-size: 2.5rem; letter-spacing: 0.1em; margin-bottom: 0.5rem; text-transform: uppercase; color: var(--color-text);">
      {{ shop.name }}
    </p>

    <p style="color: var(--color-text-muted); font-size: var(--size-sm); margin-bottom: 2.5rem; line-height: 1.6;">
      {{ section.settings.message | default: 'We're launching soon. Enter the password to preview.' }}
    </p>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p style="color: var(--color-accent); margin-bottom: 1rem; font-size: var(--size-sm);">Incorrect password — try again.</p>
      {%- endif -%}
      <div style="display: flex; border: 1px solid var(--color-border); border-radius: var(--radius-sm); overflow: hidden; margin-bottom: 1.25rem; transition: border-color var(--dur-fast);">
        <input
          type="password"
          name="password"
          placeholder="Store password"
          autocomplete="current-password"
          style="flex: 1; padding: 0.875rem 1rem; background: var(--color-surface); color: var(--color-text); font-family: var(--font-body); font-size: var(--size-body);"
        >
        <button type="submit" class="btn btn--primary" style="border-radius: 0; padding: 0.875rem 1.25rem;">Enter</button>
      </div>
    {%- endform -%}

    {%- if settings.social_instagram != blank -%}
      <a href="{{ settings.social_instagram }}" style="font-size: var(--size-xs); color: var(--color-text-muted); letter-spacing: 0.1em; text-transform: uppercase;" target="_blank" rel="noopener">
        Follow us on Instagram
      </a>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "We're launching soon. Enter the password to preview."
    }
  ],
  "presets": [{ "name": "Password page" }]
}
{% endschema %}
