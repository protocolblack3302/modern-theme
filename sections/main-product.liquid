{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image
-%}

<!-- Product data: Alpine reads from script tags to avoid HTML-entity escaping issues -->
<script id="ProductJSON-{{ product.id }}" type="application/json">
  {{ product | json }}
</script>

<script id="ProductImagesJSON-{{ product.id }}" type="application/json">
  [
    {%- for image in product.images -%}
      {"src900": {{ image | image_url: width: 900 | json }}, "src144": {{ image | image_url: width: 144 | json }}, "alt": {{ image.alt | default: product.title | json }}}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
</script>

<!-- Inventory map: per-variant stock + whether inventory is tracked -->
<script id="ProductInventoryJSON-{{ product.id }}" type="application/json">
  {
    {%- for v in product.variants -%}
      "{{ v.id }}": {"qty": {{ v.inventory_quantity | default: 0 }}, "tracked": {% if v.inventory_management != blank %}true{% else %}false{% endif %}, "policy": {{ v.inventory_policy | json }}, "available": {{ v.available }}}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  }
</script>

<section
  class="product-page"
  x-data="productPage('{{ product.id }}')"
>
  <!-- Breadcrumb -->
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {%- if collection -%}
        <a href="{{ collection.url }}" class="breadcrumb__link">{{ collection.title }}</a>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}" class="breadcrumb__link">Shop</a>
      {%- endif -%}
      <span class="breadcrumb__sep" aria-hidden="true">→</span>
      <span class="breadcrumb__current" aria-current="page">{{ product.title }}</span>
    </nav>
  </div>

  <div class="container">
    <div class="product-layout">

      <!-- ── Gallery ── -->
      <div class="product-gallery">

        <div class="product-gallery__main">
          {%- for image in product.images -%}
            <img
              class="product-gallery__main-img{% if forloop.first %} active{% endif %}"
              :class="{ active: activeImageIndex === {{ forloop.index0 }} }"
              src="{{ image | image_url: width: 900 }}"
              alt="{{ image.alt | escape | default: product.title | escape }}"
              width="900"
              height="1200"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              {% if forloop.first %}fetchpriority="high"{% endif %}
            >
          {%- endfor -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for image in product.images -%}
              <button
                class="product-gallery__thumb{% if forloop.first %} active{% endif %}"
                :class="{ active: activeImageIndex === {{ forloop.index0 }} }"
                @click="setActiveImage({{ forloop.index0 }})"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 144 }}"
                  alt="{{ image.alt | escape | default: product.title | escape }}"
                  width="72"
                  height="96"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>

      <!-- ── Details ── -->
      <div class="product-details" data-animate="fade-up">

        <p class="product-details__brand">{{ product.vendor }}</p>
        <h1 class="product-details__title">{{ product.title }}</h1>

        <!-- Price -->
        <div class="product-details__price">
          <template x-if="currentVariant && currentVariant.compare_at_price > currentVariant.price">
            <span>
              <span class="product-details__price--sale" x-text="formatMoney(currentVariant.price)"></span>
              <span class="product-details__price--compare" x-text="formatMoney(currentVariant.compare_at_price)"></span>
            </span>
          </template>
          <template x-if="!currentVariant || currentVariant.compare_at_price <= currentVariant.price">
            <span x-text="currentVariant ? formatMoney(currentVariant.price) : '{{ product.price | money }}'"></span>
          </template>
        </div>

        <!-- Stock status -->
        <div class="product-stock" x-show="ready">
          <span class="product-stock__dot" :class="stockState"></span>
          <span x-text="stockLabel"></span>
        </div>

        <!-- Variant options -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="option-group">
              <p class="option-group__label">
                {{ option.name }}:
                <span x-text="selectedOptions['{{ option.name | escape }}']"></span>
              </p>
              <div class="option-pills">
                {%- for value in option.values -%}
                  <button
                    class="option-pill"
                    :class="{
                      active: selectedOptions['{{ option.name | escape }}'] === '{{ value | escape }}',
                      unavailable: !isOptionAvailable('{{ option.name | escape }}', '{{ value | escape }}')
                    }"
                    @click="selectOption('{{ option.name | escape }}', '{{ value | escape }}')"
                  >
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- Quantity -->
        <div class="option-group">
          <p class="option-group__label">Quantity</p>
          <div class="qty-control" style="display: inline-flex; padding: 0.5rem 0.75rem;">
            <button class="qty-btn" @click="quantity = Math.max(1, quantity - 1)" aria-label="Decrease">−</button>
            <span class="qty-value" x-text="quantity"></span>
            <button
              class="qty-btn"
              @click="quantity = Math.min(quantity + 1, maxAddable)"
              :disabled="quantity >= maxAddable"
              aria-label="Increase"
            >+</button>
          </div>
        </div>

        <!-- Add to cart -->
        <div class="product-details__atc">
          <template x-if="currentVariant && currentVariant.available && !atCartLimit">
            <button
              class="btn btn--primary btn--full"
              @click="addToCart()"
              :disabled="addingToCart"
            >
              <span x-show="!addingToCart && !addedToCart">Add to Cart</span>
              <span x-show="addingToCart" style="display:none">Adding...</span>
              <span x-show="addedToCart" style="display:none">Added ✓</span>
            </button>
          </template>
          <template x-if="currentVariant && currentVariant.available && atCartLimit">
            <button class="btn btn--ghost btn--full" disabled style="opacity:0.65; cursor:not-allowed;">
              Max qty in cart
            </button>
          </template>
          <template x-if="!currentVariant || !currentVariant.available">
            <button class="btn btn--ghost btn--full" disabled style="opacity:0.45; cursor:not-allowed;">
              Sold Out
            </button>
          </template>
        </div>

        <!-- Description -->
        {%- if product.description != blank -%}
          <div class="product-details__desc rte">
            {{ product.description }}
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "Main product" }]
}
{% endschema %}
