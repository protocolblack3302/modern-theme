<div class="section" style="padding-top: 0;">
  <div class="container main-cart-container">
    <h1 class="section-title main-cart-title" data-animate="fade-up">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div class="main-cart-layout">

          <!-- Items -->
          <div>
            {%- for item in cart.items -%}
              <div class="cart-item">
                <a href="{{ item.url }}">
                  <img
                    class="cart-item__img"
                    src="{{ item.image | image_url: width: 160 }}"
                    alt="{{ item.title | escape }}"
                    width="80"
                    height="107"
                    loading="lazy"
                  >
                </a>
                <div class="cart-item__details">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <p class="cart-item__price">{{ item.final_price | money }}</p>
                  <div class="cart-item__footer">
                    <div class="qty-control">
                      <a href="{{ routes.cart_change_url }}?id={{ item.key | url_encode }}&quantity={{ item.quantity | minus: 1 }}" class="qty-btn" aria-label="Decrease quantity">−</a>
                      <span class="qty-value">{{ item.quantity }}</span>
                      {%- assign _at_max = false -%}
                      {%- if item.variant.inventory_management != blank and item.variant.inventory_policy == 'deny' and item.quantity >= item.variant.inventory_quantity -%}
                        {%- assign _at_max = true -%}
                      {%- endif -%}
                      {%- if _at_max -%}
                        <span class="qty-btn qty-btn--disabled" aria-disabled="true" aria-label="Increase quantity">+</span>
                      {%- else -%}
                        <a href="{{ routes.cart_change_url }}?id={{ item.key | url_encode }}&quantity={{ item.quantity | plus: 1 }}" class="qty-btn" aria-label="Increase quantity">+</a>
                      {%- endif -%}
                    </div>
                    <a href="{{ routes.cart_change_url }}?id={{ item.key | url_encode }}&quantity=0" class="cart-item__remove">{{ 'cart.remove' | t }}</a>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <!-- Summary -->
          <div class="main-cart-summary">
            <h2 class="main-cart-summary__title">{{ 'cart.subtotal' | t }}</h2>
            <div class="cart-subtotal">
              <span class="cart-subtotal__label">{{ 'cart.subtotal' | t }}</span>
              <span class="cart-subtotal__amount">{{ cart.total_price | money }}</span>
            </div>
            <p class="cart-note">Taxes and shipping calculated at checkout</p>
            <button type="submit" name="checkout" class="btn btn--primary btn--full">{{ 'cart.checkout' | t }}</button>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost btn--full">{{ 'cart.continue_shopping' | t }}</a>
          </div>

        </div>
      </form>
    {%- else -%}
      <div class="main-cart-empty">
        <p class="main-cart-empty__text">{{ 'cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">{{ 'cart.continue_shopping' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}
