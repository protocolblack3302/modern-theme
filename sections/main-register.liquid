<div class="section account-page" style="padding-top: calc(72px + 4rem);">
  <div class="container">
    <div class="account-form-wrap" data-animate="fade-up">
      <h1 class="account-title">Create Account</h1>

      {%- form 'create_customer' -%}
        {%- if form.errors -%}
          <div class="form-errors">
            {%- for field in form.errors -%}
              <p>{{ form.errors.messages[field] }}</p>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="form-grid-2">
          <div class="form-group">
            <label for="reg-first" class="form-label">First Name</label>
            <input type="text" id="reg-first" name="customer[first_name]" value="{{ form.first_name }}" autocomplete="given-name" class="form-input">
          </div>
          <div class="form-group">
            <label for="reg-last" class="form-label">Last Name</label>
            <input type="text" id="reg-last" name="customer[last_name]" value="{{ form.last_name }}" autocomplete="family-name" class="form-input">
          </div>
        </div>
        <div class="form-group">
          <label for="reg-email" class="form-label">Email <span style="color:var(--color-accent)">*</span></label>
          <input type="email" id="reg-email" name="customer[email]" value="{{ form.email }}" autocomplete="email" required class="form-input">
        </div>
        <div class="form-group">
          <label for="reg-password" class="form-label">Password <span style="color:var(--color-accent)">*</span></label>
          <input type="password" id="reg-password" name="customer[password]" autocomplete="new-password" required class="form-input">
          <p style="font-size: var(--size-xs); color: var(--color-text-muted); margin-top: 0.4rem;">Min. 5 characters</p>
        </div>

        <button type="submit" class="btn btn--primary">Create Account</button>
      {%- endform -%}

      <p class="account-switch">Already have an account? <a href="{{ routes.account_login_url }}">Log in</a></p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Register",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "Register" }]
}
{% endschema %}
