<div style="padding-top: calc(72px + 4rem); padding-bottom: var(--section-gap);">
  <div class="container">
    <div class="page-content" data-animate="fade-up">
      <h1>{{ page.title }}</h1>
      <div class="rte">{{ page.content }}</div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "Page" }]
}
{% endschema %}
