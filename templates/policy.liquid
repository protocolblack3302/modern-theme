{% layout 'theme' %}

<div style="padding-top: calc(72px + 4rem); padding-bottom: var(--section-gap);">
  <div class="container">
    <div class="page-content" data-animate="fade-up">

      {%- if policy == blank -%}
        <h1>Policy</h1>
        <p style="color: var(--color-text-muted);">This policy has not been added yet.</p>
      {%- else -%}
        <h1>{{ policy.title }}</h1>
        <div class="rte" style="margin-top: 2rem;">{{ policy.body }}</div>
      {%- endif -%}

    </div>
  </div>
</div>
