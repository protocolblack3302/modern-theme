{% layout 'theme' %}

<div class="policy-section" data-animate="fade-up">
  <div class="container">
    <div class="policy-body">

      {%- if policy == blank -%}
        <h1>Policy</h1>
        <p class="policy-empty">This policy has not been added yet.</p>
      {%- else -%}
        {{ policy.body }}
      {%- endif -%}

    </div>
  </div>
</div>